# OpenAI Vision (GPT-4o) — required for AI dimension extraction, furniture
# classification, and the /digitize/hybrid endpoint. Without it, the app
# falls back to Tesseract OCR + OpenCV-only classification.
OPENAI_API_KEY=

# PostgreSQL — Central Brain (ML lessons, proportion learning). Matches
# docker-compose.yml service defaults; override for your environment.
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=cad_digitizer
PG_USER=postgres
PG_PASSWORD=postgres
