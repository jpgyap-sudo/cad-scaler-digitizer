{
  "id": "casework.rectangular.v1",
  "name": "Rectangular casework / sideboard",
  "product_type": "sideboard",
  "family": "casework",
  "parameters": [
    {
      "name": "length_mm",
      "default": 1800,
      "min_value": 400,
      "max_value": 3000
    },
    {
      "name": "depth_mm",
      "default": 450,
      "min_value": 300,
      "max_value": 650
    },
    {
      "name": "height_mm",
      "default": 800,
      "min_value": 350,
      "max_value": 1300
    },
    {
      "name": "door_count",
      "default": 4,
      "min_value": 0,
      "max_value": 8
    },
    {
      "name": "drawer_count",
      "default": 0,
      "min_value": 0,
      "max_value": 8
    },
    {
      "name": "panel_thickness_mm",
      "default": 18,
      "min_value": 12,
      "max_value": 30
    }
  ],
  "components": [
    {
      "id": "case",
      "role": "case",
      "shape": "rectangular_box",
      "material_role": "casework",
      "parameter_map": {
        "length_mm": "length_mm",
        "depth_mm": "depth_mm",
        "height_mm": "height_mm",
        "thickness_mm": "panel_thickness_mm"
      }
    },
    {
      "id": "fronts",
      "role": "doors_or_drawers",
      "shape": "front_panel_array",
      "material_role": "casework",
      "parameter_map": {
        "door_count": "door_count",
        "drawer_count": "drawer_count",
        "length_mm": "length_mm",
        "height_mm": "height_mm"
      }
    },
    {
      "id": "base",
      "role": "base",
      "shape": "recessed_plinth",
      "material_role": "base",
      "parameter_map": {
        "length_mm": "length_mm",
        "depth_mm": "depth_mm"
      }
    }
  ],
  "constraints": [
    {
      "id": "case_depth",
      "description": "Casework depth should be 300-650mm",
      "expression": "300 <= depth_mm <= 650",
      "severity": "warning"
    },
    {
      "id": "fronts_exist",
      "description": "At least one door or drawer should exist",
      "expression": "door_count + drawer_count >= 1",
      "severity": "info"
    }
  ],
  "required_views": [
    "top",
    "front_elevation",
    "side_elevation",
    "section"
  ],
  "required_details": [
    "case_section",
    "front_reveal_detail",
    "hardware_detail"
  ],
  "drawing_notes": [
    "SHOW DOOR/DRAWER REVEALS.",
    "SHOW PANEL THICKNESS AND HARDWARE DETAIL."
  ]
}