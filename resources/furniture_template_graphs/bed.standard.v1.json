{
  "id": "bed.standard.v1",
  "name": "Standard platform bed",
  "product_type": "bed",
  "family": "bed",
  "parameters": [
    {
      "name": "length_mm",
      "default": 2030,
      "min_value": 1900,
      "max_value": 2200,
      "description": "Bed length"
    },
    {
      "name": "depth_mm",
      "default": 1830,
      "min_value": 1350,
      "max_value": 2000,
      "description": "Bed width"
    },
    {
      "name": "height_mm",
      "default": 1000,
      "min_value": 800,
      "max_value": 1200,
      "description": "Overall bed height (incl headboard)"
    },
    {
      "name": "platform_height_mm",
      "default": 300,
      "min_value": 200,
      "max_value": 500,
      "description": "Mattress platform height"
    }
  ],
  "components": [
    {
      "id": "platform",
      "role": "mattress_zone",
      "shape": "rectangular_platform",
      "material_role": "platform",
