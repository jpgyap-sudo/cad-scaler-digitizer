        "length_mm": "length_mm",
        "depth_mm": "depth_mm",
        "height_mm": "height_mm"
      }
    },
    {
      "id": "headboard",
      "role": "headboard",
      "shape": "vertical_panel",
      "material_role": "headboard",
      "parameter_map": {}
    }
  ],
  "constraints": [
    {
      "id": "bed_min_size",
      "description": "Minimum bed size is 1900x1350mm",
