{
  "id": "table.dual_cylindrical_pedestal.v1",
  "name": "Dual cylindrical pedestal dining table",
  "product_type": "dining_table",
  "family": "table",
  "parameters": [
    {
      "name": "length_mm",
      "default": 1800,
      "min_value": 1200,
      "max_value": 3200,
      "description": "Overall table length"
    },
    {
      "name": "depth_mm",
      "default": 900,
      "min_value": 650,
      "max_value": 1400
    },
    {
      "name": "height_mm",
      "default": 750,
      "min_value": 720,
      "max_value": 780
    },
    {
      "name": "top_thickness_mm",
      "default": 30,
      "min_value": 18,
      "max_value": 80
    },
    {
      "name": "large_pedestal_diameter_mm",
      "default": 420,
      "min_value": 250,
      "max_value": 700
    },
    {
      "name": "small_pedestal_diameter_mm",
      "default": 220,
      "min_value": 120,
      "max_value": 450
    },
    {
      "name": "left_pedestal_x_mm",
      "default": -420
    },
    {
      "name": "right_pedestal_x_mm",
      "default": 420
    },
    {
      "name": "pedestal_height_mm",
      "default": 720
    }
  ],
  "components": [
    {
      "id": "top",
      "role": "top",
      "shape": "rectangular_slab",
      "material_role": "top",
      "parameter_map": {
        "length_mm": "length_mm",
        "depth_mm": "depth_mm",
        "thickness_mm": "top_thickness_mm"
      }
    },
    {
      "id": "large_pedestal",
      "role": "support",
      "shape": "cylinder",
      "material_role": "base",
      "parameter_map": {
        "diameter_mm": "large_pedestal_diameter_mm",
        "height_mm": "pedestal_height_mm",
        "x_mm": "left_pedestal_x_mm",
        "y_mm": "zero"
      }
    },
    {
      "id": "small_pedestal",
      "role": "support",
      "shape": "cylinder",
      "material_role": "base",
      "parameter_map": {
        "diameter_mm": "small_pedestal_diameter_mm",
        "height_mm": "pedestal_height_mm",
        "x_mm": "right_pedestal_x_mm",
        "y_mm": "zero"
      }
    },
    {
      "id": "hidden_frame",
      "role": "joinery",
      "shape": "rectangular_steel_frame",
      "visible": false,
      "material_role": "steel",
      "parameter_map": {
        "length_mm": "length_mm",
        "depth_mm": "depth_mm"
      }
    }
  ],
  "constraints": [
    {
      "id": "height_range",
      "description": "Dining table height should be 720-780mm",
      "expression": "720 <= height_mm <= 780",
      "severity": "warning"
    },
    {
      "id": "pedestal_ratio",
      "description": "Large pedestal should be larger than small pedestal",
      "expression": "large_pedestal_diameter_mm > small_pedestal_diameter_mm",
      "severity": "error"
    },
    {
      "id": "top_span",
      "description": "Long stone table should include hidden frame",
      "expression": "length_mm <= 2200 or top_thickness_mm >= 30",
      "severity": "warning"
    }
  ],
  "required_views": [
    "top",
    "front_elevation",
    "side_elevation"
  ],
  "required_details": [
    "top_thickness_detail",
    "pedestal_mounting_detail",
    "hidden_frame_detail"
  ],
  "drawing_notes": [
    "SHOW HIDDEN STEEL FRAME UNDER STONE TOP.",
    "SHOW PEDESTAL DIAMETERS AND POSITIONS."
  ]
}