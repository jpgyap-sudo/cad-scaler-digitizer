{
  "id": "wardrobe.standard.v1",
  "name": "Standard wardrobe",
  "product_type": "wardrobe",
  "family": "cabinet",
  "parameters": [
    {
      "name": "length_mm",
      "default": 1200,
      "min_value": 800,
      "max_value": 2500,
      "description": "Wardrobe width"
    },
    {
      "name": "depth_mm",
      "default": 600,
      "min_value": 500,
      "max_value": 750,
      "description": "Wardrobe depth"
    },
    {
      "name": "height_mm",
      "default": 2000,
      "min_value": 1800,
      "max_value": 2600,
