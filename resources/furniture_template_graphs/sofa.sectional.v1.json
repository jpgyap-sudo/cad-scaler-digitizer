{
  "id": "sofa.sectional.v1",
  "name": "L-shaped sectional sofa / couch",
  "product_type": "sectional",
  "family": "seating",
  "parameters": [
    { "name": "length_mm", "default": 2800, "min_value": 2000, "max_value": 4000, "description": "Long side overall length" },
    { "name": "depth_mm", "default": 950, "min_value": 800, "max_value": 1200, "description": "Overall depth" },
    { "name": "height_mm", "default": 820, "min_value": 700, "max_value": 950, "description": "Overall height" },
    { "name": "chaise_length_mm", "default": 1600, "min_value": 1200, "max_value": 2200, "description": "Chaise section length" },
    { "name": "seat_height_mm", "default": 420, "min_value": 380, "max_value": 460, "description": "Seat height" },
    { "name": "seat_count", "default": 4, "min_value": 3, "max_value": 6, "description": "Total seat modules" }
  ],
  "components": [
    { "id": "main_seat", "role": "seat", "shape": "upholstered_block", "material_role": "upholstery", "parameter_map": { "length_mm": "length_mm", "depth_mm": "depth_mm", "height_mm": "seat_height_mm" } },
    { "id": "chaise_seat", "role": "seat", "shape": "upholstered_block", "material_role": "upholstery", "parameter_map": { "length_mm": "chaise_length_mm", "depth_mm": "depth_mm", "height_mm": "seat_height_mm" } },
    { "id": "back", "role": "back", "shape": "upholstered_back", "material_role": "upholstery", "parameter_map": {} },
    { "id": "arms", "role": "arms", "shape": "rectangular_arm_block", "quantity": 2, "material_role": "upholstery", "parameter_map": {} },
    { "id": "base", "role": "base", "shape": "low_plinth_or_legs", "material_role": "base", "parameter_map": {} }
  ],
  "constraints": [{ "id": "chaise_shorter", "description": "Chaise must be shorter than total length", "expression": "chaise_length_mm < length_mm", "severity": "error" }],
  "required_views": ["top", "front_elevation", "side_elevation"],
  "required_details": ["sectional_join_detail"],
  "drawing_notes": ["SECTIONAL SOFA — CONFIRM LEFT/RIGHT CONFIGURATION."]
}
