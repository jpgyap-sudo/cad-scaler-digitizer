      "parameters": { "layer": "HATCH" },
      "expected_polyline": {
        "points": [ [0, 0], [80, 0], [80, 4], [0, 4] ],
        "closed": true,
        "layer": "HATCH"
      },
      "note": "Hatch boundaries are drawn via hatch.paths.add_polyline_path(), not msp.add_lwpolyline(). The geometry is the same but the API differs.",
      "hatch_method": "msp.add_hatch(color=8).paths.add_polyline_path(vertices, is_closed=True)"
    }
