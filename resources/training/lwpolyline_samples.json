  "classification_rules": [
    {
      "condition": "shape has 4 sides at ~90° angles",
      "entity_type": "LWPOLYLINE with close=True",
      "example": "All rectangular outlines: tabletop, cabinet, sofa, wardrobe"
    },
    {
      "condition": "shape is a circle or arc",
      "entity_type": "CIRCLE or ARC",
      "note": "NEVER approximate circles with LWPOLYLINE — always use true CIRCLE"
    },
    {
      "condition": "shape is a single structural line",
      "entity_type": "LINE",
      "example": "Centerlines, hidden shelf lines, dimension lines"
    },
    {
      "condition": "shape has 3+ non-rectangular sides",
      "entity_type": "LWPOLYLINE with close=True",
      "example": "Trapezoidal pedestal neck, tapered base, angled supports"
    },
    {
      "condition": "shape is an open path",
      "entity_type": "LWPOLYLINE with close=False",
      "example": "Profiles, partial outlines, section cuts"
    }
  ],
  "common_mistakes": [
    {
      "mistake": "Using 4 LINE entities for a rectangle",
      "fix": "Replace with 1 LWPOLYLINE with close=True",
      "entities_saved": "3 fewer entities"
    },
    {
      "mistake": "Approximating a circle with LWPOLYLINE or LINE segments",
      "fix": "Use msp.add_circle(center, radius) instead",
      "impact": "CIRCLE is a true primitive, no approximation needed"
    },
    {
      "mistake": "Using LINE for centerlines when they could be LWPOLYLINE",
      "fix": "Centerlines should remain LINE (they're open, single-segment). Only closed shapes need LWPOLYLINE."
    },
    {
      "mistake": "Zero-length segments from duplicate adjacent points",
      "fix": "Validate points array before creating LWPOLYLINE",
      "validation": "if len(points) >= 2 and all(p != points[i-1] for i, p in enumerate(points))"
    }
  ]
}
