# =============================================================================
# MCP Server — ChatGPT can connect to control the CAD digitizer
# =============================================================================
FROM node:20-alpine

WORKDIR /app

# Install only production dependencies (mcp sdk + axios)
COPY mcp-server/package.json ./
RUN npm install --omit=dev

# Copy server source
COPY mcp-server/ ./

EXPOSE 3003
HEALTHCHECK --interval=30s --timeout=10s --retries=3 --start-period=5s \
  CMD wget -qO- http://localhost:3003/health --timeout=5 || exit 1
ENV NODE_ENV=production

# SSE transport for Docker — listens on port 3003
# For ChatGPT Desktop, use stdio mode locally (without --sse)
CMD ["node", "server.js", "--sse"]
