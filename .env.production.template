# =============================================================================
# CAD Scaler Digitizer — Production Environment Template
# Copy to .env and fill in all values
# =============================================================================
FRONTEND_PORT=443
NODE_API_PORT=4000
PYTHON_WORKER_PORT=8001

# Domain for SSL cert
DOMAIN=cad.yourdomain.com

# Auth — generate with: openssl rand -hex 32
AUTH_TOKEN=replace-with-random-64-char-hex-string

# PostgreSQL
PG_USER=cad_app
PG_PASSWORD=replace-with-strong-password
PG_DATABASE=cad_reference_library

# Redis
REDIS_PASSWORD=replace-with-strong-password

# DigitalOcean Spaces (S3-compatible storage)
SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
SPACES_REGION=sgp1
SPACES_BUCKET=your-bucket-name
SPACES_KEY=your-spaces-key
SPACES_SECRET=your-spaces-secret
SPACES_CDN_BASE=https://your-bucket.sgp1.cdn.digitaloceanspaces.com/cad-reference-library

# Qdrant
QDRANT_URL=http://qdrant:6333
